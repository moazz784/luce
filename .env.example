# Copy to `.env.local` for local dev. On Vercel (production SPA: https://luce-six.vercel.app ), set the same name in
# Project Settings → Environment Variables. No trailing slash on the API URL.
#
# Production API (MonsterASP / runasp.net): https://luce.runasp.net
# The built-in default in src/Api.js matches this if you omit the variable.
#
# Local dev (default): omit this variable — the app uses /api on the Vite dev server and vite.config.js proxies to http://localhost:5009.
# Direct to API instead: VITE_API_BASE_URL=http://localhost:5009
VITE_API_BASE_URL=https://luce.runasp.net
