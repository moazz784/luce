# Copy to `.env.local` for local dev. On Vercel, set the same name in Project Settings → Environment Variables.
# No trailing slash. Use https:// for production (required when the site is HTTPS — mixed content blocks http:// API calls).
#
# Local dev (default): omit this variable — the app uses /api on the Vite dev server and vite.config.js proxies to http://localhost:5009.
# Direct to API instead: VITE_API_BASE_URL=http://localhost:5009
VITE_API_BASE_URL=https://your-api-host.example
